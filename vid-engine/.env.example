# 硅基流动 API Key（用于 ASR 语音识别 + Embedding）
SILICONFLOW_API_KEY=sk-your-key-here

# DeepSeek API Key（用于结构化处理）
DEEPSEEK_API_KEY=sk-your-key-here

# 智谱 API Key（用于 GLM-4V 视频理解，可选）
ZHIPUAI_API_KEY=your-key-here

# Tavily API Key（用于对话 Agent 互联网检索，可选）
# 配置后，对话助手可在需要时自动搜索最新资讯
# 申请地址：https://app.tavily.com
# TAVILY_API_KEY=tvly-your-key-here

# --- 可选调优参数（不填则使用默认值） ---

# LLM 并行线程数（默认 4）
# LLM_MAX_WORKERS=4

# 是否启用 embedding 磁盘缓存（默认 true）
# EMBED_CACHE_ENABLED=true

# 缓存目录（默认 .cache）
# VID_CACHE_DIR=.cache
